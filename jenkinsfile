pipeline {
    agent any

    stages {

        stage('Checkout GIT') {
            steps {
                echo "Pulling project..."
                git branch: 'main',
                    url: 'https://github.com/yazz-Sh/Jenkins-Springboot.git'
            }
        }

        stage('Maven Clean') {
            steps {
                sh 'mvn clean'
            }
        }

        stage('Maven Compile') {
            steps {
                sh 'mvn compile'
            }
        }

        stage('Maven Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                sh '''
                mvn sonar:sonar \
                -Dsonar.host.url=http://localhost:9000 \
                -Dsonar.login=admin \
                -Dsonar.password=TON_MDP
                '''
            }
        }
    }
}
